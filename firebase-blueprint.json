{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["role", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Barber shop appointment",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who booked" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "time": { "type": "string", "description": "HH:MM" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "cancelled"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "serviceId", "serviceName", "date", "time", "name", "phone", "status", "createdAt", "updatedAt"]
    },
    "Service": {
      "title": "Service",
      "description": "Barber shop service",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "price", "duration", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Settings and profile for users"
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Appointments booked by customers"
    },
    "/services/{serviceId}": {
      "schema": { "$ref": "#/entities/Service" },
      "description": "Available salon services managed by admin"
    }
  }
}
